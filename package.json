{
  "name": "mrc-viewer",
  "displayName": "mrc-viewer",
  "description": "MRC volume viewer for cryo-EM",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mrc-viewer.volume",
        "displayName": "MRC Volume Viewer",
        "selector": [
          {
            "filenamePattern": "*.mrc"
          },
          {
            "filenamePattern": "*.mrcs"
          },
          {
            "filenamePattern": "*.map"
          },
          {
            "filenamePattern": "*.ccp4"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "molstar": "^5.10.1"
  }
}
